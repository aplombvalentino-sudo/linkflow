# linkflow â€” environment variables. Copy to `.env.local` and fill in.
# `.env.local` is gitignored. NEVER commit real values.

# ---- Firebase (web config — from Project settings › General › Your apps) ----
# These are public identifiers, not secrets; access is governed by Firestore
# Security Rules. `your-project` in the id keeps the app in demo mode.
NEXT_PUBLIC_FIREBASE_API_KEY=your-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# ---- Firebase Admin (service account — Project settings › Service accounts) ----
# SERVER-ONLY. NEVER prefix with NEXT_PUBLIC_. Paste the private key with its
# literal \n escapes intact (the Admin client restores real newlines).
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ---- App / Legal (RGPD â€” required by legal-compliance-agent) ----
NEXT_PUBLIC_APP_URL=https://linkflows.xyz
NEXT_PUBLIC_COMPANY_NAME=Your Company SAS
NEXT_PUBLIC_CONTACT_EMAIL=contact@your-domain.com

# ---- Stripe (only if the spec enables billing) ----
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Vercel auto-deploy (read by deployment-agent / vercel-auto-deploy) ----
# Create at https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-token
# Personal account: leave empty. Set only if deploying under a Vercel team.
VERCEL_TEAM_ID=

# ---- Cloudflare Turnstile (bot protection on login/signup) ----
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile.
# Site key is public (ships to the browser); secret key is server-only and
# verifies solves in POST /api/auth/session. Leave both unset to skip the
# check entirely (no widget renders, no server-side gate) — useful for local
# dev without a Turnstile account.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
