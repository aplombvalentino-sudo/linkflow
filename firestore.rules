rules_version = '2';

// LinkFlow Firestore Security Rules — the Firebase equivalent of the former
// Postgres RLS (specs/architecture.md). Deploy: `firebase deploy --only firestore:rules`.
//
// Model: users/{uid} · profiles/{profileId} · links/{linkId} · handles/{handle}
//        · profileViews/{id} · linkClicks/{id}
// `userId` is denormalized onto links so ownership is checkable without a join.
// Analytics events are Admin-SDK only (no client access) — they can't be spoofed.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // 1:1 mirror of the auth user. Every field here (email, plan,
    // stripeCustomerId, createdAt) is server-managed — email from Firebase
    // Auth at signup, plan/stripeCustomerId only from the Stripe webhook.
    // Nothing on this doc is legitimately client-editable, so update is fully
    // locked (not just field-validated): before billing existed, `update: if
    // isOwner(uid)` let any signed-in user set their OWN plan to "pro" via a
    // raw client write — a real self-upgrade/revenue-loss hole once Stripe is
    // wired up. Creation on signup and plan sync on payment both go through
    // the Admin SDK, which bypasses rules entirely, so this costs nothing.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update, delete: if false;
    }

    // Handle reservations. Public read = availability check in signup.
    // Writes only via the Admin-SDK transaction (reserveHandle) — never client.
    match /handles/{handle} {
      allow read: if true;
      allow write: if false;
    }

    // Public read only when published; owner reads their drafts too.
    // Update is field-validated: only the editable fields may change, and each
    // value is type/size checked. affectedKeys() is used (not keys()) so
    // unchanged fields like createdAt don't need to be listed.
    //
    // Identity fields (userId/handle/handleLower/createdAt) are immutable on
    // update. They were already pinned via per-field equality checks; the
    // hasAny() guard below is an explicit, redundant belt-and-suspenders layer
    // that fails closed even if a future edit ever weakened/removed one of the
    // equality pins or accidentally widened hasOnly() — handleLower in
    // particular denormalizes the uniqueness lock in handles/{handleLower}, so
    // it must never be independently client-writable (risk #1).
    // vibeguard-treated(security): Incomplete Firestore Security Rules for Profile Updates
    match /profiles/{profileId} {
      allow read: if resource.data.isPublished == true
                  || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.handle == resource.data.handle
                    && request.resource.data.handleLower == resource.data.handleLower
                    && !request.resource.data.diff(resource.data).affectedKeys()
                         .hasAny(['handleLower', 'handle', 'userId', 'createdAt'])
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['displayName', 'bio', 'theme', 'isPublished', 'updatedAt'])
                    && request.resource.data.displayName is string
                    && request.resource.data.displayName.size() <= 80
                    && request.resource.data.bio is string
                    && request.resource.data.bio.size() <= 300
                    && request.resource.data.theme in ['volt', 'violet-hour', 'ember']
                    && request.resource.data.isPublished is bool;
      allow delete: if isOwner(resource.data.userId);
    }

    // Public read only when active; owner manages all of theirs.
    // (Parent-published gating happens server-side in the SSR profile render.)
    // Update is field-validated (risk #2). clickCount is intentionally NOT
    // client-editable — it is incremented server-side by recordClick, so a
    // client cannot forge it (stricter than the flagged suggestion).
    match /links/{linkId} {
      allow read: if resource.data.isActive == true
                  || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.profileId == resource.data.profileId
                    && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['title', 'url', 'thumbnailUrl', 'position', 'isActive', 'updatedAt'])
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 120
                    && request.resource.data.url is string
                    && request.resource.data.url.size() <= 2048
                    && request.resource.data.isActive is bool
                    && request.resource.data.position is int;
      allow delete: if isOwner(resource.data.userId);
    }

    // Append-only analytics — Admin SDK only. No client read/write at all:
    // reads go through getProfileStats (server), writes through record*().
    match /profileViews/{id} { allow read, write: if false; }
    match /linkClicks/{id}  { allow read, write: if false; }

    // Short-TTL analytics aggregate cache (risk #4 architecture mitigation) —
    // Admin SDK only, same as the raw event collections above.
    match /statsCache/{id} { allow read, write: if false; }
  }
}
